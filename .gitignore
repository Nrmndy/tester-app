*.tmp
*.autosave
*~
._*
.nfs*

# ======================================================================
# Системные файлы
# ======================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ======================================================================
# IDE и редакторы
# ======================================================================

# Qt Creator
*.autosave
*.qmlproject.user
*.qmlproject.user.*

# Visual Studio (если используется)
.vs/
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# CLion / CMake
cmake-build-*/
CMakeLists.txt.user

# Vim
*.swp
*.swo

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# VS Code
.vscode/

# NetBeans
nbproject/

# ======================================================================
# Логи и профилирование
# ======================================================================
*.log
*.trc
*.prf

# ======================================================================
# Дополнительные артефакты Qt
# ======================================================================
qtc-*
*.qmlc
*.jsc
*.pyc

# ======================================================================
# Дистрибутивы и упаковка
# ======================================================================
dist/
packaging/
deploy/

# ======================================================================
# Пользовательские конфигурационные файлы (не для репозитория)
